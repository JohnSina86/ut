# Database settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password_here
DB_NAME=ut

# Server settings
PORT=4000
NODE_ENV=development

# Frontend origin (used for CORS and post-payment redirects)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your_secret_key_here

# ----- PayPal -----
# Create a REST app at https://developer.paypal.com and copy the sandbox
# client id / secret here. Switch PAYPAL_MODE to `live` for production.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----- Stripe (used for Google Pay via PaymentRequest) -----
# Secret key from https://dashboard.stripe.com/apikeys. The webhook secret
# comes from any endpoint you register on the Stripe dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- GoCardless (Direct Debit) -----
# Get an access token from https://manage.gocardless.com. Set the environment
# to `sandbox` while testing and `live` in production. The redirect URL must
# point back at this API so we can finalise the mandate after the customer
# authorises it on the hosted flow.
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_REDIRECT_URL=http://localhost:4000/api/payments/direct-debit/callback
GOCARDLESS_WEBHOOK_SECRET=
