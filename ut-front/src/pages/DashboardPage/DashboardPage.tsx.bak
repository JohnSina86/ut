import React from 'react';
import { Header }          from '../../components/layout/Header/Header';
import { Footer }          from '../../components/layout/Footer/Footer';
import { Container }       from '../../components/layout/Container/Container';
import { Section }         from '../../components/layout/Section/Section';
import { Grid }            from '../../components/layout/Grid/Grid';
import { AppointmentCard } from '../../components/shared/AppointmentCard/AppointmentCard';
import { Badge }           from '../../components/ui/Badge/Badge';
import styles from './DashboardPage.module.css';

const UPCOMING = [
  { id: 'a1', serviceName: 'Tyre Change',   vehicleInfo: 'Toyota Corolla – 191-D-1234', date: '2025-07-15', time: '10:00', duration: 30, status: 'upcoming' as const, price: 80  },
  { id: 'a2', serviceName: 'Oil Change',    vehicleInfo: 'Honda Civic – 201-D-5678',    date: '2025-07-20', time: '14:00', duration: 20, status: 'upcoming' as const, price: 45  },
];

const STATS = [
  { label: 'Total Bookings',    value: '12' },
  { label: 'Upcoming',          value: '2'  },
  { label: 'Vehicles Saved',    value: '3'  },
  { label: 'Loyalty Points',    value: '340'},
];

export const DashboardPage = () => {
  return (
    <div className={styles.page}>
      <Header />
      <main className={styles.main}>

        {/* Welcome banner */}
        <div className={styles.welcomeBanner}>
          <Container>
            <h1 className={styles.welcomeTitle}>Welcome back, John ??</h1>
            <p className={styles.welcomeSub}>Here's an overview of your account.</p>
          </Container>
        </div>

        {/* Stats */}
        <Section>
          <Container>
            <Grid columns={4} gap="md">
              {STATS.map((stat) => (
                <div key={stat.label} className={styles.statCard}>
                  <span className={styles.statValue}>{stat.value}</span>
                  <span className={styles.statLabel}>{stat.label}</span>
                </div>
              ))}
            </Grid>
          </Container>
        </Section>

        {/* Upcoming appointments */}
        <Section title="Upcoming Appointments">
          <Container>
            {UPCOMING.length === 0 ? (
              <p className={styles.empty}>No upcoming appointments. <a href="/booking">Book one now ?</a></p>
            ) : (
              <div className={styles.appointmentList}>
                {UPCOMING.map((appt) => (
                  <AppointmentCard
                    key={appt.id}
                    {...appt}
                    onViewDetails={(id) => console.log('View details:', id)}
                    onReschedule={(id)  => console.log('Reschedule:',   id)}
                    onCancel={(id)      => console.log('Cancel:',        id)}
                  />
                ))}
              </div>
            )}
          </Container>
        </Section>

        {/* Quick actions */}
        <Section title="Quick Actions" background="gray">
          <Container>
            <div className={styles.quickActions}>
              <a href="/booking"      className={styles.actionBtn}>?? Book a Service</a>
              <a href="/vehicles"     className={styles.actionBtn}>?? Manage Vehicles</a>
              <a href="/appointments" className={styles.actionBtn}>?? All Appointments</a>
              <a href="/settings"     className={styles.actionBtn}>?? Account Settings</a>
            </div>
          </Container>
        </Section>

      </main>
      <Footer copyright="© 2025 United Tyres Dundrum." />
    </div>
  );
};

export default DashboardPage;

