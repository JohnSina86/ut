.page { min-height: 100vh; display: flex; flex-direction: column; background: #f9fafb; }
.main { flex: 1; display: flex; align-items: center; padding: 3rem 0; }
.card {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  width: 100%;
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
}
.resetLink { text-align: center; font-size: 0.82rem; }
.resetLink a { color: #2563eb; }
